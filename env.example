# ══════════════════════════════════════════════════════════
# .env.example — Modèle de configuration
# Copie ce fichier en .env et remplis les vraies valeurs
# NE JAMAIS committer le vrai .env sur GitHub !
# ══════════════════════════════════════════════════════════

# MongoDB Atlas — remplace <username> et <password>
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Nom de la base de données
DB_NAME=banque_senegal

# Clé secrète Flask (génère une valeur aléatoire)
SECRET_KEY=change-moi-avec-une-vraie-cle-secrete

# Mode debug (False en production)
DEBUG=False
